---
import Layout from "../layouts/Layout.astro";
import Icon from "../icons/search.svg";
---

<Layout
	title="Cyberkey Domain Services"
	description="Your domain, email, and trust resource."
>
	<main>
		<h1>Get the perfect domain.</h1>
		<form action="">
			<input
				name="domain"
				type="text"
				placeholder="Enter the domain you want"
			/>
			<button><Icon name="search" /></button>
		</form>
	</main>
</Layout>
<style lang="scss">
	main {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-direction: column;

		h1 {
			text-align: center;
		}
	}

	form {
		display: flex;

		input {
			border: 1px groove #fff;
			border-top-left-radius: 4px;
			border-bottom-left-radius: 4px;
			padding: 0.5rem 2rem;
			width: 350px;

			&::placeholder {
				width: 100%;
				text-align: center;
			}
		}
		button {
			background: #fff;
			border-top-right-radius: 4px;
			border-bottom-right-radius: 4px;
			color: #113260;
			cursor: pointer;
		}
	}
</style>
